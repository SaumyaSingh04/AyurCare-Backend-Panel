        },
        {
          "name": "Add Address",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/addresses",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Saumya Singh\",\n  \"phone\": \"6388691336\",\n  \"addressLine1\": \"123 Main Street\",\n  \"addressLine2\": \"Near City Mall\",\n  \"city\": \"Lucknow\",\n  \"state\": \"Uttar Pradesh\",\n  \"pincode\": \"226001\",\n  \"label\": \"Home\",\n  \"isDefault\": true\n}"
            }
          }
        },
        {
          "name": "Update Address",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/addresses/ADDRESS_ID_HERE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"city\": \"Kanpur\",\n  \"pincode\": \"208001\"\n}"
