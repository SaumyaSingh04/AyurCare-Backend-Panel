        {
          "name": "Set Default Address",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/addresses/ADDRESS_ID_HERE/default",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get Wishlist",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/wishlist",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Toggle Wishlist",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/wishlist/PRODUCT_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "category", "value": "", "disabled": true },
                { "key": "sort", "value": "-createdAt", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/search?q=herbal",
              "host": ["{{baseUrl}}"],
              "path": ["products", "search"],
              "query": [{ "key": "q", "value": "herbal" }]
            }
          }
        },
        {
          "name": "Featured Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/featured"
