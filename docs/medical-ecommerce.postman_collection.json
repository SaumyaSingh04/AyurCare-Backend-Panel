          }
        },
        {
          "name": "Delete Address",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/addresses/ADDRESS_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
