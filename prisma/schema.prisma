generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  user
  admin
  super_admin
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  out_for_delivery
  delivered
  cancelled
  return_requested
  returned
  refunded
  failed
}

enum PaymentStatus {
  pending
  created
  authorized
  captured
  paid
  failed
  refunded
  partially_refunded
  cancelled
}

enum PaymentMethod {
  razorpay
  stripe
  cod
  wallet
}

enum CouponType {
  percentage
  flat
  free_shipping
  buy_x_get_y
}

enum NotificationType {
  order_placed
  order_confirmed
  order_shipped
  order_delivered
  order_cancelled
  order_returned
  payment_success
  payment_failed
  refund_initiated
  refund_success
  promo
  system
}

enum BlogStatus {
  draft
  published
  archived
}

// ─── User ─────────────────────────────────────────────────────────────────────
// addresses[]    → Json[]   (embedded sub-docs, always read with user)
// wishlist[]     → String[] (array of productIds, matches user.wishlist[ObjectId])
// refreshTokens  → String[] (backend reads/replaces whole array)
// avatar         → flat columns (avatarUrl, avatarPublicId)

model User {
  id                  String    @id @default(uuid())
  firstName           String    @db.VarChar(50)
  lastName            String    @db.VarChar(50)
  email               String    @unique @db.VarChar(255)
  phone               String?   @unique @db.VarChar(15)
  password            String?
  role                Role      @default(user)

  avatarUrl           String?
  avatarPublicId      String?

  isEmailVerified     Boolean   @default(false)
  isPhoneVerified     Boolean   @default(false)
  isActive            Boolean   @default(true)

  // addresses: Json[] — shape matches addressSchema { label, fullName, phone,
  //   addressLine1, addressLine2, city, state, pincode, country, isDefault, id }
  addresses           Json[]    @default([])

  // wishlist: String[] of productIds — matches user.wishlist behavior
  wishlist            String[]  @default([])

  otp                 String?
  otpExpiry           DateTime?
  otpAttempts         Int       @default(0)

  passwordResetToken  String?
  passwordResetExpiry DateTime?

  refreshTokens       String[]  @default([])

  googleId            String?   @unique

  lastLogin           DateTime?
  loginAttempts       Int       @default(0)
  lockUntil           DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  orders        Order[]
  payments      Payment[]
  reviews       Review[]
  cart          Cart?
  notifications Notification[]
  blogs         Blog[]
  wishlistRef   Wishlist?

  @@index([role, isActive])
  @@index([createdAt(sort: Desc)])
}

// ─── Category ─────────────────────────────────────────────────────────────────
// ancestors[] → String[] of categoryIds (matches ancestors: [ObjectId] shape)
// Self-relation preserved for parent/children hierarchy

model Category {
  id              String     @id @default(uuid())
  name            String     @db.VarChar(100)
  slug            String     @unique @db.VarChar(150)
  description     String?    @db.VarChar(500)

  imageUrl        String?
  imagePublicId   String?

  parentId        String?
  // ancestors: String[] of categoryIds — matches .ancestors array in Mongoose
  ancestors       String[]   @default([])
  level           Int        @default(0)

  isActive        Boolean    @default(true)
  sortOrder       Int        @default(0)

  metaTitle       String?
  metaDescription String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]  @relation("ProductCategory")
  subProducts Product[]  @relation("ProductSubcategory")

  @@index([parentId, isActive])
  @@index([ancestors])
}

// ─── Product ──────────────────────────────────────────────────────────────────
// variants[]        → Json[] (embedded variantSchema, always read with product)
// images[]          → Json[] (shape: [{ url, publicId, alt }])
// thumbnail         → flat columns
// relatedProducts[] → String[] of productIds (no join table)
// dimensions        → flat columns (dimensionLength, dimensionWidth, dimensionHeight)

model Product {
  id               String   @id @default(uuid())
  name             String   @db.VarChar(300)
  slug             String   @unique @db.VarChar(350)
  description      String
  shortDescription String?  @db.VarChar(500)
  brand            String?

  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  costPrice      Decimal? @db.Decimal(10, 2)

  hasVariants Boolean @default(false)
  // variants: Json[] — shape matches variantSchema exactly
  variants    Json[]  @default([])

  categoryId    String
  subcategoryId String?
  tags          String[] @default([])

  // images: Json[] — shape: [{ url, publicId, alt }]
  images            Json[]  @default([])
  thumbnailUrl      String?
  thumbnailPublicId String?

  sku               String?  @unique
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  trackInventory    Boolean  @default(true)

  averageRating Decimal @default(0) @db.Decimal(3, 1)
  ratingCount   Int     @default(0)
  totalSold     Int     @default(0)

  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)
  isDigital  Boolean @default(false)

  metaTitle       String?
  metaDescription String?
  metaKeywords    String[] @default([])

  weight          Decimal? @db.Decimal(10, 2)
  dimensionLength Decimal? @db.Decimal(8, 2)
  dimensionWidth  Decimal? @db.Decimal(8, 2)
  dimensionHeight Decimal? @db.Decimal(8, 2)

  // relatedProducts: String[] of productIds — no join table
  relatedProducts String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category    Category  @relation("ProductCategory", fields: [categoryId], references: [id])
  subcategory Category? @relation("ProductSubcategory", fields: [subcategoryId], references: [id])
  reviews     Review[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([categoryId, isActive])
  @@index([isFeatured, isActive])
  @@index([price, averageRating(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ─── Cart ─────────────────────────────────────────────────────────────────────
// CartItem is its own table (items are updated individually by productId/variantId)
// savedForLater is a separate array in Mongoose — modelled as savedForLater Boolean
// on CartItem to avoid a duplicate table (same fields, same schema)

model Cart {
  id             String   @id @default(uuid())
  userId         String   @unique
  couponCode     String?
  couponDiscount Decimal  @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  productId String

  // variantDetails: flat columns — matches cartItemSchema.variantDetails shape
  variantId    String?
  variantName  String?
  variantSku   String?
  variantColor String?
  variantSize  String?

  quantity       Int      @default(1)
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  thumbnail      String?
  name           String?
  slug           String?

  // savedForLater: replaces the duplicate savedForLater[cartItemSchema] array
  savedForLater Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([cartId])
}

// ─── Order ────────────────────────────────────────────────────────────────────
// shippingAddress → flat columns (snapshot, used in invoice/PDF generation)
// statusHistory[] → Json[] (always read with order, never filtered independently)
// tracking        → Json  (always read with order as one object)
// items           → OrderItem table (needed for per-product admin reports)

model Order {
  id          String @id @default(uuid())
  orderNumber String @unique
  userId      String

  subtotal              Decimal @db.Decimal(10, 2)
  shippingCharge        Decimal @default(0) @db.Decimal(10, 2)
  taxAmount             Decimal @default(0) @db.Decimal(10, 2)
  discount              Decimal @default(0) @db.Decimal(10, 2)
  couponCode            String?
  couponDiscount        Decimal @default(0) @db.Decimal(10, 2)
  codConfirmationCharge Decimal @default(0) @db.Decimal(10, 2)
  totalAmount           Decimal @db.Decimal(10, 2)

  // shippingAddress snapshot — flat columns match orderSchema.shippingAddress shape
  shippingFullName     String?
  shippingPhone        String?
  shippingAddressLine1 String?
  shippingAddressLine2 String?
  shippingCity         String?
  shippingState        String?
  shippingPincode      String?
  shippingCountry      String  @default("India")

  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(pending)
  paymentId     String?

  status OrderStatus @default(pending)

  // statusHistory: Json[] — shape: [{ status, note, updatedBy, timestamp }]
  statusHistory Json[] @default([])

  // tracking: Json — shape: { carrier, trackingNumber, trackingUrl, estimatedDelivery, events[] }
  tracking Json?

  invoiceNumber String?
  invoiceUrl    String?

  customerNote String?
  adminNote    String?

  cancellationReason String?
  returnReason       String?
  returnRequestedAt  DateTime?
  cancelledAt        DateTime?
  deliveredAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User       @relation(fields: [userId], references: [id])
  payment Payment?   @relation(fields: [paymentId], references: [id])
  items   OrderItem[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([paymentStatus])
}

// ─── OrderItem ────────────────────────────────────────────────────────────────
// Own table: needed for admin product-sales reports and stock decrement logic
// variantDetails → flat columns (matches orderItemSchema.variantDetails shape)

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String?

  variantId    String?
  name         String
  slug         String?
  thumbnail    String?
  sku          String?
  // variantDetails: flat columns — matches { name, color, size }
  variantName  String?
  variantColor String?
  variantSize  String?

  quantity       Int
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  totalPrice     Decimal  @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ─── Payment ──────────────────────────────────────────────────────────────────
// refunds[]       → Json[] (shape matches refundSchema, always read with payment)
// webhookEvents[] → Json[] (raw storage, never queried independently)
// gatewayResponse → Json  (Mixed in Mongoose)

model Payment {
  id       String        @id @default(uuid())
  userId   String
  provider PaymentMethod
  status   PaymentStatus @default(pending)
  amount   Decimal       @db.Decimal(10, 2)
  currency String        @default("INR")

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  stripePaymentIntentId String?
  stripeClientSecret    String?

  transactionId   String?
  gatewayResponse Json?

  // refunds: Json[] — shape: [{ amount, reason, status, refundId, processedAt }]
  refunds       Json[]  @default([])
  totalRefunded Decimal @default(0) @db.Decimal(10, 2)

  // webhookEvents: Json[] — shape: [{ event, payload, receivedAt }]
  webhookEvents Json[] @default([])

  paidAt         DateTime?
  failedAt       DateTime?
  failureCode    String?
  failureMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([razorpayOrderId])
  @@index([stripePaymentIntentId])
}

// ─── Review ───────────────────────────────────────────────────────────────────
// images[]  → Json[]   (always read with review, shape: [{ url, publicId }])
// votedBy[] → String[] (preserves .push()/.includes() pattern in service)
// reply     → flat columns (matches review.reply.message access pattern)

model Review {
  id        String  @id @default(uuid())
  productId String
  userId    String
  orderId   String?

  rating  Int
  title   String? @db.VarChar(200)
  comment String  @db.VarChar(2000)

  // images: Json[] — shape: [{ url, publicId }]
  images Json[] @default([])

  isVerifiedPurchase Boolean @default(false)
  isApproved         Boolean @default(true)
  isHidden           Boolean @default(false)
  helpfulVotes       Int     @default(0)

  // votedBy: String[] of userIds — preserves array operations in service layer
  votedBy String[] @default([])

  // reply: flat columns — matches review.reply.{ message, repliedAt, repliedBy }
  replyMessage     String?
  replyRepliedAt   DateTime?
  replyRepliedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([productId, userId])
  @@index([productId, isApproved, createdAt(sort: Desc)])
}

// ─── Coupon ───────────────────────────────────────────────────────────────────
// usedBy[]               → String[] of userIds
// applicableProducts[]   → String[] of productIds
// applicableCategories[] → String[] of categoryIds
// excludedProducts[]     → String[] of productIds
// All checked in-memory after fetching coupon (existing behavior — no join tables)

model Coupon {
  id             String     @id @default(uuid())
  code           String     @unique @db.VarChar(100)
  type           CouponType
  value          Decimal    @db.Decimal(10, 2)
  maxDiscount    Decimal?   @db.Decimal(10, 2)
  minOrderAmount Decimal    @default(0) @db.Decimal(10, 2)
  description    String?
  isActive       Boolean    @default(true)
  startDate      DateTime   @default(now())
  endDate        DateTime
  usageLimit     Int?
  usagePerUser   Int        @default(1)
  totalUsed      Int        @default(0)
  freeShipping   Boolean    @default(false)

  usedBy               String[] @default([])
  applicableProducts   String[] @default([])
  applicableCategories String[] @default([])
  excludedProducts     String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([endDate, isActive])
}

// ─── Notification ─────────────────────────────────────────────────────────────
// data (Mixed) → Json
// TTL (30-day expiry) must be handled by a cron job — no native TTL in PostgreSQL

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  icon      String?
  actionUrl String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
}

// ─── Blog ─────────────────────────────────────────────────────────────────────
// coverImage → flat columns (coverImageUrl, coverImagePublicId, coverImageAlt)
// tags[], metaKeywords[] → String[]

model Blog {
  id      String @id @default(uuid())
  title   String @db.VarChar(300)
  slug    String @unique @db.VarChar(350)
  content String
  excerpt String? @db.VarChar(500)

  authorId String

  category String @default("General")
  tags     String[] @default([])

  coverImageUrl      String?
  coverImagePublicId String?
  coverImageAlt      String?

  status      BlogStatus @default(draft)
  publishedAt DateTime?

  views Int @default(0)
  likes Int @default(0)

  metaTitle       String?  @db.VarChar(60)
  metaDescription String?  @db.VarChar(160)
  metaKeywords    String[] @default([])

  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([status, publishedAt(sort: Desc)])
  @@index([authorId, status])
  @@index([isFeatured, status])
  @@index([tags])
}

// ─── Wishlist ─────────────────────────────────────────────────────────────────
// products[{ product, addedAt }] → Json[] — preserves shape exactly
// One-to-one with User (unique: true in Mongoose)

model Wishlist {
  id     String @id @default(uuid())
  userId String @unique

  // items: Json[] — shape: [{ productId, addedAt }]
  items Json[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
